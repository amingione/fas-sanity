{
  "compilerOptions": {
    "target": "ES2017",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleDetection": "force",
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "noEmit": true,
    "outDir": "./dist",
    "paths": {
      "@fas/sanity-config/*": ["./packages/sanity-config/src/*"],
      "@/*": ["./src/*"],
      "netlify/*": ["./netlify/*"]
    }
  },
  "include": [
    "sanity.config.ts",
    "sanity.cli.ts",
    "netlify/functions",
    "netlify/lib",
    "src",
    "scripts",
    "shared",
    "packages/sanity-config",
    "env.d.ts",
    "*.ts",
    "*.tsx"
  ],
  "exclude": [
    "node_modules",
    "archive",
    "scripts/archive",
    "scripts/deprecated-medusa",
    "packages/sanity-config/src/schemaTypes/objects/buildQuote.ts"
  ]
}
